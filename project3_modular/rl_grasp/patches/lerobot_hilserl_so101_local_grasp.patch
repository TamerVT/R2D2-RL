+def target_color_onehot(color_name: str) -> torch.Tensor:
+    if color_name not in TARGET_COLOR_ORDER:
+        raise ValueError(
+            f"Unknown target color '{color_name}'. "
+            f"Expected one of {TARGET_COLOR_ORDER}."
+        )
+
+    vec = torch.zeros(len(TARGET_COLOR_ORDER), dtype=torch.float32)
+    vec[TARGET_COLOR_ORDER.index(color_name)] = 1.0
+    return vec
+
+
+def select_target_color_for_episode(env: gym.Env) -> None:
+    import sys
+    import termios
+
+    # Discard stray keyboard-event characters such as 's' or 'r'
+    # that may still be sitting in the terminal input buffer from
+    # the previous episode.
+    try:
+        termios.tcflush(sys.stdin, termios.TCIFLUSH)
+    except termios.error:
+        pass
+
+    while True:
+        raw = input(
+            "\n[Target color] Choose "
+            "b=blue, g=green, p=purple, o=orange, y=yellow, r=red: "
+        ).strip().lower()
+
+        if raw in TARGET_COLOR_KEY_TO_NAME:
+            color_name = TARGET_COLOR_KEY_TO_NAME[raw]
+            env.target_color_name = color_name
+            env.target_color_onehot = target_color_onehot(color_name)
+            print(
+                f"[Target color] Using {color_name}: "
+                f"{env.target_color_onehot.tolist()}\n"
+            )
+            return
+
+        print(f"[Target color] Invalid key: {raw!r}")
 
