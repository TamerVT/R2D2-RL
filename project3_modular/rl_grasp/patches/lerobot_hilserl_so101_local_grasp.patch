new file mode 100644
index 00000000..5e6a0f91
--- /dev/null
+++ b/scripts/add_bowl_goal_from_task_labels.py
@@ -0,0 +1,235 @@
+#!/usr/bin/env python3
+"""
+Add bowl target coordinates to a LeRobot v3 dataset as
+
+    observation.environment_state = [bowl_x, bowl_y, bowl_z]
+
+by parsing episode task strings of the form:
+
+    Task1_x-0.15_y0.45_z0.00
+
+The script:
+- copies the original dataset to a new output folder,
+- reads each episode's task label,
+- parses x/y/z,
+- writes observation.environment_state into every frame,
+- updates meta/info.json,
+- updates meta/stats.json.
+"""
+
+from __future__ import annotations
+
+import argparse
+import json
+import re
+import shutil
+from pathlib import Path
+from typing import Any
+
+import numpy as np
+import pandas as pd
+
+
+FEATURE_KEY = "observation.environment_state"
+FEATURE_NAMES = ["bowl_x", "bowl_y", "bowl_z"]
+
+TASK_PATTERN = re.compile(
+    r"^Task1_x(?P<x>[+-]?\d+(?:\.\d+)?)"
+    r"_y(?P<y>[+-]?\d+(?:\.\d+)?)"
+    r"_z(?P<z>[+-]?\d+(?:\.\d+)?)$"
+)
+
+
+def parse_args() -> argparse.Namespace:
+    parser = argparse.ArgumentParser()
+    parser.add_argument("--input-root", type=Path, required=True)
+    parser.add_argument("--output-root", type=Path, required=True)
+    parser.add_argument("--overwrite", action="store_true")
+    return parser.parse_args()
+
+
+def copy_dataset(input_root: Path, output_root: Path, overwrite: bool) -> None:
+    if not input_root.exists():
+        raise FileNotFoundError(f"Input dataset does not exist: {input_root}")
+
+    if output_root.exists():
+        if not overwrite:
+            raise FileExistsError(
+                f"Output dataset already exists: {output_root}\n"
+                "Pass --overwrite to replace it."
+            )
+        shutil.rmtree(output_root)
+
+    shutil.copytree(input_root, output_root)
+
+
+def load_episode_goal_map(root: Path) -> dict[int, np.ndarray]:
+    episodes_files = sorted((root / "meta" / "episodes").rglob("*.parquet"))
+    if not episodes_files:
+        raise FileNotFoundError(f"No episode metadata found under {root / 'meta' / 'episodes'}")
+
+    episodes = pd.concat(
+        [pd.read_parquet(f) for f in episodes_files],
+        ignore_index=True,
+    )
+
+    if "episode_index" not in episodes.columns:
+        raise KeyError("Episode metadata has no 'episode_index' column.")
+    if "tasks" not in episodes.columns:
+        raise KeyError("Episode metadata has no 'tasks' column.")
+
+    if episodes["episode_index"].duplicated().any():
+        dups = episodes.loc[
+            episodes["episode_index"].duplicated(keep=False),
+            ["episode_index", "tasks"],
+        ]
+        raise RuntimeError(
+            "Duplicate episode indices found in metadata. Please repair the dataset first:\n"
+            + dups.to_string(index=False)
+        )
+
+    episode_to_goal: dict[int, np.ndarray] = {}
+
+    for _, row in episodes.iterrows():
+        ep_idx = int(row["episode_index"])
+        tasks = row["tasks"]
+
+        # In LeRobot episode metadata, tasks is often stored as a list-like object.
+        if isinstance(tasks, (list, tuple, np.ndarray)):
+            if len(tasks) != 1:
+                raise ValueError(f"Episode {ep_idx} has unexpected tasks field: {tasks}")
+            task = str(tasks[0])
+        else:
+            task = str(tasks)
+
+        match = TASK_PATTERN.match(task)
+        if match is None:
+            raise ValueError(
+                f"Could not parse task label for episode {ep_idx}: {task!r}\n"
+                "Expected format: Task1_x-0.15_y0.45_z0.00"
+            )
+
+        goal = np.array(
+            [
+                float(match.group("x")),
+                float(match.group("y")),
+                float(match.group("z")),
+            ],
+            dtype=np.float32,
+        )
+        episode_to_goal[ep_idx] = goal
+
+    return episode_to_goal
+
+
+def augment_data_parquets(
+    root: Path,
+    episode_to_goal: dict[int, np.ndarray],
+) -> np.ndarray:
+    data_files = sorted((root / "data").rglob("*.parquet"))
+    if not data_files:
+        raise FileNotFoundError(f"No data parquet files found under {root / 'data'}")
+
+    all_goal_rows: list[np.ndarray] = []
+    seen_episodes: set[int] = set()
+
+    for parquet_path in data_files:
+        df = pd.read_parquet(parquet_path)
+
+        if "episode_index" not in df.columns:
+            raise KeyError(f"{parquet_path} has no 'episode_index' column.")
+
+        env_values = []
+        for ep_idx in df["episode_index"].to_numpy():
+            ep_idx = int(ep_idx)
+            if ep_idx not in episode_to_goal:
+                raise ValueError(f"No bowl goal found for episode {ep_idx}.")
+            goal = episode_to_goal[ep_idx].astype(np.float32, copy=True)
+            env_values.append(goal)
+            all_goal_rows.append(goal)
+            seen_episodes.add(ep_idx)
+
+        df[FEATURE_KEY] = env_values
+        df.to_parquet(parquet_path, index=False)
+
+    unused = sorted(set(episode_to_goal) - seen_episodes)
+    if unused:
+        raise RuntimeError(f"Episode goals exist for episodes not found in frame data: {unused}")
+
+    return np.stack(all_goal_rows, axis=0)
+
+
+def update_info_json(root: Path) -> None:
+    info_path = root / "meta" / "info.json"
+    info = json.loads(info_path.read_text())
+
+    features = info.setdefault("features", {})
+    features[FEATURE_KEY] = {
+        "dtype": "float32",
+        "shape": [3],
+        "names": FEATURE_NAMES,
+    }
+
+    info_path.write_text(json.dumps(info, indent=4) + "\n")
+
+
+def vector_stats(values: np.ndarray) -> dict[str, Any]:
+    return {
+        "min": values.min(axis=0).astype(float).tolist(),
+        "max": values.max(axis=0).astype(float).tolist(),
+        "mean": values.mean(axis=0).astype(float).tolist(),
+        "std": values.std(axis=0).astype(float).tolist(),
+        "count": [int(values.shape[0])],
+        "q01": np.quantile(values, 0.01, axis=0).astype(float).tolist(),
+        "q10": np.quantile(values, 0.10, axis=0).astype(float).tolist(),
+        "q50": np.quantile(values, 0.50, axis=0).astype(float).tolist(),
+        "q90": np.quantile(values, 0.90, axis=0).astype(float).tolist(),
+        "q99": np.quantile(values, 0.99, axis=0).astype(float).tolist(),
+    }
+
+
+def update_stats_json(root: Path, all_goal_rows: np.ndarray) -> None:
+    stats_path = root / "meta" / "stats.json"
+    stats = json.loads(stats_path.read_text())
+    stats[FEATURE_KEY] = vector_stats(all_goal_rows)
+    stats_path.write_text(json.dumps(stats, indent=4) + "\n")
+
+
+def sanity_check(root: Path) -> None:
+    info = json.loads((root / "meta" / "info.json").read_text())
+    stats = json.loads((root / "meta" / "stats.json").read_text())
+
+    assert FEATURE_KEY in info["features"], f"{FEATURE_KEY} missing in info.json"
+    assert FEATURE_KEY in stats, f"{FEATURE_KEY} missing in stats.json"
+
+    first_file = sorted((root / "data").rglob("*.parquet"))[0]
+    df = pd.read_parquet(first_file)
+    assert FEATURE_KEY in df.columns, f"{FEATURE_KEY} missing in {first_file}"
+
+    print("\nSanity check passed.")
+    print(f"Example environment state: {np.asarray(df.iloc[0][FEATURE_KEY]).tolist()}")
+    print(f"Augmented dataset written to:\n  {root}")
+
+
+def main() -> None:
+    args = parse_args()
+
+    print("Copying dataset...")
+    copy_dataset(args.input_root, args.output_root, args.overwrite)
+
+    print("Parsing task labels...")
+    episode_to_goal = load_episode_goal_map(args.output_root)
+    print(f"Parsed bowl coordinates for {len(episode_to_goal)} episodes.")
+
+    print("Adding observation.environment_state to frame data...")
+    all_goal_rows = augment_data_parquets(args.output_root, episode_to_goal)
+
+    print("Updating metadata...")
+    update_info_json(args.output_root)
+    update_stats_json(args.output_root, all_goal_rows)
+
+    sanity_check(args.output_root)
+
+
+if __name__ == "__main__":
+    main()
