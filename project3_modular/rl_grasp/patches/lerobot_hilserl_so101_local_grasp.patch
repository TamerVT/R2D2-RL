+
+    def flaky_read_from_hardware():
+        nonlocal attempts
+
+        attempts += 1
+        if attempts <= 12:
+            raise RuntimeError("temporary camera drop")
+
+        camera.stop_event.set()
+        return np.zeros((1, 1, 3), dtype=np.uint8)
+
+    camera._read_from_hardware = flaky_read_from_hardware
+
+    camera._read_loop()
+
+    assert attempts == 13
