<mujoco>   
    <asset>
        <texture name="noise"
                 type="2d"
                 builtin="flat"
                 width="256"
                 height="256"
                 rgb1="0.5 0.5 0.5"/>
        
        <material name="noise_mat"
                texture="noise"
                texrepeat="10 10"/>

        <material name="ground_mat"
                rgba="0.72 0.68 0.66 1"/>
    </asset>
    <worldbody>

        <geom name="background"
              type="plane"
              size="10 10 0.1"
              pos="0 0 -0.001"
              material="noise_mat"/>

        <geom name="ground"
              type="plane"
              size="1.5 1.5 0.1"
              pos="0 0 0"
              material="ground_mat"/>

    </worldbody>

</mujoco>
